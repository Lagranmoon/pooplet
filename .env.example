# Pooplet 环境变量配置 / Environment Variables Configuration

# ============================================
# Docker 镜像配置 / Docker Image Configuration
# ============================================

# 使用的镜像地址 / Image to use
# 默认值: ghcr.io/lagranmoon/pooplet
# POOPLE_IMAGE=ghcr.io/lagranmoon/pooplet

# 镜像标签 / Image tag
# 可用值: latest, main, v1.0.0, 等
# 默认值: latest
# POOPLE_TAG=latest

# ============================================
# 端口配置 / Port Configuration
# ============================================

# 应用访问端口 / Application port
# 默认值: 3000
# POOPLE_PORT=3000

# ============================================
# 安全配置 / Security Configuration
# ============================================

# JWT 密钥（生产环境必须设置）
# JWT secret key (required for production)
# 建议使用随机生成的强密码
# JWT_SECRET=your-super-secret-key-here

# ============================================
# 数据目录 / Data Directory
# ============================================

# SQLite 数据库目录 / SQLite database directory
# 默认值: ./data
# DATA_DIR=./data
